# ============================================================
#  TODO (YOU): Fill in all values below before running the app
# ============================================================

# MongoDB connection string (e.g. mongodb+srv://user:pass@cluster.mongodb.net/couplesapp)
MONGODB_URI=your_mongodb_connection_string_here

# JWT secret — pick any long random string
JWT_SECRET=your_super_secret_jwt_key_here

# Cloudinary credentials — found in your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Port for the Express server
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
